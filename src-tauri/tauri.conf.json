{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JMS Universal Video Downloader",
  "version": "0.1.0",
  "identifier": "com.jms.ytdownloader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JMS Universal Video Downloader",
        "width": 800,
        "height": 700,
        "minWidth": 500,
        "minHeight": 500,
        "theme": "Dark",
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
      "externalBin": [
        "binaries/yt-dlp",
        "binaries/ffmpeg",
        "binaries/whisper"
      ],
      "resources": [
        "binaries/whisper.dll",
        "binaries/ggml.dll",
        "binaries/ggml-base.dll",
        "binaries/ggml-cpu-x64.dll"
      ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
